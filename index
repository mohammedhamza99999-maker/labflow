  function getTrans(str){
    const raw=String(str==null?'':str);
    const trimmed=raw.replace(/\s+/g,' ').trim();
    if(!trimmed) return raw;
    if(currentLang==='ar') return raw;
    const d=dict[currentLang]||{};
    if(d[trimmed]) return raw.replace(trimmed,d[trimmed]);
    return raw;
  }
  function translateTextNode(node){
    if(!node || !node.nodeValue || !node.nodeValue.trim()) return;
    const parent=node.parentElement;
    if(!parent || skipTags[parent.tagName] || parent.closest('.mono,pre,code,[data-no-i18n],.qr-fake,.barcode')) return;
    if(!textMemory.has(node)) textMemory.set(node,node.nodeValue);
    const original=textMemory.get(node);
    node.nodeValue=(currentLang==='ar')?original:getTrans(original);
  }
  function translateAttrs(root){
    const attrs=['placeholder','title','aria-label'];
    (root||document).querySelectorAll('input,textarea,button,select,option,[title],[aria-label]').forEach(function(el){
      attrs.forEach(function(a){
        if(!el.hasAttribute(a)) return;
        const k='lfV50Orig'+a.replace(/-/g,'_');
        if(!el.dataset[k]) el.dataset[k]=el.getAttribute(a)||'';
        const original=el.dataset[k];
        el.setAttribute(a,(currentLang==='ar')?original:getTrans(original));
      });
    });
  }
  function translatePage(root){
    try{
      const r=root||document.body;
      const walker=document.createTreeWalker(r,NodeFilter.SHOW_TEXT,{acceptNode:function(n){
        const p=n.parentElement; if(!p || skipTags[p.tagName] || p.closest('.mono,pre,code,[data-no-i18n],.qr-fake,.barcode')) return NodeFilter.FILTER_REJECT;
        return n.nodeValue && n.nodeValue.trim()?NodeFilter.FILTER_ACCEPT:NodeFilter.FILTER_REJECT;
      }});
      const nodes=[]; while(walker.nextNode()) nodes.push(walker.currentNode);
      nodes.forEach(translateTextNode);
      translateAttrs(r);
      document.documentElement.lang=currentLang==='en'?'en':(currentLang==='ku'?'ku':'ar');
      document.documentElement.dir=currentLang==='en'?'ltr':'rtl';
      document.body.dir=currentLang==='en'?'ltr':'rtl';
      document.body.classList.toggle('lf-ltr-v50',currentLang==='en');
      document.body.classList.toggle('lf-ku-v50',currentLang==='ku');
      document.querySelectorAll('.lang-switch-v50 button[data-lang]').forEach(function(b){b.classList.toggle('active',b.dataset.lang===currentLang);});
    }catch(e){console.warn(PATCH,'translatePage failed',e);}
  }
