      @media print{
        .v58-hero-logo,.water.v58-water{
          -webkit-print-color-adjust:exact!important;
          print-color-adjust:exact!important;
        }
      }
    `;
  }

  function enhancePrintHtml(html){
    if(!html || typeof html !== 'string') return html;

    // إذا كان مطبق سابقاً لا نكرر
    if(html.includes('v58-hero-logo')) return html;

    const src = logoSrc();
    const logo = src ? '<img class="v58-hero-logo" src="'+escAttr(src)+'" alt="Lab logo">' : '';

    // أضف CSS داخل نفس ستايل الورقة حتى ما يخرب المقاسات
    if(/<\/style>/i.test(html)){
      html = html.replace(/<\/style>/i, safePrintCss() + '</style>');
    }else{
      html = html.replace(/<\/head>/i, '<style>'+safePrintCss()+'</style></head>');
    }

    // اللوغو داخل الهيدر فقط، وليس فوق الورقة
    if(logo){
      html = html.replace(/<div class="title">/i, '<div class="title">'+logo);
