/* ===== V38: reliable doctor save + doctor accounting save fix ===== */
(function(){
  const PATCH='V38_DOCTOR_SAVE_FIX';
  const DOCTOR_KEY='labflow_saved_doctors_integrated_v1';
  const MAIN_KEY='labflow_no_login_test_v10_light_ui';
  const $id=(id)=>document.getElementById(id);
  const esc=(v)=>String(v==null?'':v).replace(/[&<>'"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[m]));
  const makeDocId=()=> 'doc_'+Date.now().toString(36)+'_'+Math.random().toString(36).slice(2,8);
  function safeMsg(type,text){
    try{ if(typeof msg==='function'){ msg(type,text); return; } }catch(e){}
    let box=$id('v38DoctorMsg');
    if(!box){
      const form=$id('savedDoctorForm')||$id('doctorRateForm');
      box=document.createElement('div'); box.id='v38DoctorMsg'; box.className='alert ok'; box.style.display='block';
      if(form) form.insertAdjacentElement('afterend',box); else document.body.appendChild(box);
    }
    box.style.display='block'; box.className='alert '+(type==='err'?'err':'ok'); box.textContent=text;
    clearTimeout(box._t); box._t=setTimeout(()=>{box.style.display='none'},3500);
  }
  function readMain(){try{return JSON.parse(localStorage.getItem(MAIN_KEY)||'{}')||{}}catch(e){return {}}}
  function writeMain(data){try{localStorage.setItem(MAIN_KEY,JSON.stringify(data||{}))}catch(e){}}
  function normalizeDocs(arr){
    const seen=new Set();
    return (Array.isArray(arr)?arr:[]).map(d=>({
      id:String(d&&d.id||makeDocId()),
      name:String(d&&d.name||'').trim(),
      spec:String(d&&d.spec||''),
      phone:String(d&&d.phone||''),
      rate:Number(d&&d.rate)||0,
      createdAt:d&&d.createdAt||new Date().toISOString(),
      updatedAt:d&&d.updatedAt||''
    })).filter(d=>{
      if(!d.name) return false;
      const k=d.name.toLowerCase(); if(seen.has(k)) return false; seen.add(k); return true;
    });
  }
  function loadDocs(){
    let docs=[];
    try{docs=JSON.parse(localStorage.getItem(DOCTOR_KEY)||'[]')||[]}catch(e){docs=[]}
    if(!docs.length){ const m=readMain(); docs=m.savedDoctors||m.doctors||[]; }
    return normalizeDocs(docs);
  }
  function saveDocs(docs){
    docs=normalizeDocs(docs);
    try{localStorage.setItem(DOCTOR_KEY,JSON.stringify(docs))}catch(e){}
    const m=readMain();
    m.savedDoctors=docs;
    m.doctorRates=Array.isArray(m.doctorRates)?m.doctorRates:[];
    docs.forEach(d=>{
      const i=m.doctorRates.findIndex(x=>String(x.name||'').trim()===d.name);
      if(i>=0){m.doctorRates[i].rate=Number(d.rate)||0;}
      else m.doctorRates.push({name:d.name,rate:Number(d.rate)||0,paid:0});
    });
    m.updatedAt=new Date().toISOString();
    writeMain(m);
    try{
      if(typeof doctorRates!=='undefined'){
        doctorRates=Array.isArray(doctorRates)?doctorRates:[];
        docs.forEach(d=>{
          const old=doctorRates.find(x=>String(x.name||'').trim()===d.name);
          if(old) old.rate=Number(d.rate)||0;
          else doctorRates.push({name:d.name,rate:Number(d.rate)||0,paid:0});
        });
      }
    }catch(e){}
    try{ if(typeof save==='function') save(); }catch(e){}
    return docs;
  }
  function refreshSelect(selected){
    const el=$id('oDoctor'); if(!el) return;
    const val=selected!==undefined?selected:el.value;
    const opts=['<option value="">بدون طبيب</option>'].concat(loadDocs().map(d=>`<option value="${esc(d.name)}"${d.name===val?' selected':''}>${esc(d.name)}${d.spec?' — '+esc(d.spec):''}</option>`));
    el.innerHTML=opts.join('');
  }
  function doctorRateForFixed(name){return Number((loadDocs().find(d=>d.name===name)||{}).rate)||0}
  function doctorPaidForFixed(name){
    try{return Number((Array.isArray(doctorRates)?doctorRates:[]).find(x=>String(x.name||'').trim()===String(name||'').trim())?.paid)||0}catch(e){return 0}
  }
  function renderSavedDoctors(){
    const body=$id('savedDoctorsBody');
    if(body){
      const docs=loadDocs();
      body.innerHTML=docs.map(d=>`<tr><td><b>${esc(d.name)}</b></td><td>${esc(d.spec||'-')}</td><td>${esc(d.phone||'-')}</td><td>${esc(d.rate||0)}%</td><td><button type="button" class="btn small ghost" onclick="editSavedDoctor('${esc(d.id)}')">تعديل</button> <button type="button" class="btn small danger" onclick="deleteSavedDoctor('${esc(d.id)}')">حذف</button></td></tr>`).join('')||'<tr><td colspan="5">لا يوجد أطباء محفوظين</td></tr>';
    }
    const map={};
    try{(Array.isArray(orders)?orders:[]).forEach(o=>{const name=String(o.doctor||'').trim(); if(!name)return; if(!map[name])map[name]={count:0,total:0,paid:0,remain:0}; map[name].count++; map[name].total+=Number(o.total)||0; map[name].paid+=Number(o.paid)||0; map[name].remain+=Number(o.remain)||0;});}catch(e){}
    const rows=Object.entries(map).sort((a,b)=>b[1].total-a[1].total);
    if($id('docCount')) $id('docCount').textContent=rows.length;
    if($id('docTotal')) $id('docTotal').textContent=(typeof money==='function'?money(rows.reduce((s,[,v])=>s+v.total,0)):rows.reduce((s,[,v])=>s+v.total,0));
    if($id('docPaid')) $id('docPaid').textContent=(typeof money==='function'?money(rows.reduce((s,[name])=>s+doctorPaidForFixed(name),0)):rows.reduce((s,[name])=>s+doctorPaidForFixed(name),0));
    const db=$id('doctorsBody');
    if(db){
      db.innerHTML=rows.map(([name,v])=>{const rate=doctorRateForFixed(name),due=v.total*rate/100,paid=doctorPaidForFixed(name);return `<tr><td><b>${esc(name)}</b></td><td>${v.count}</td><td>${typeof money==='function'?money(v.total):v.total}</td><td>${rate}%</td><td>${typeof money==='function'?money(due):due}</td><td>${typeof money==='function'?money(paid):paid}</td><td>${typeof money==='function'?money(due-paid):due-paid}</td></tr>`}).join('')||'<tr><td colspan="7">لا توجد إحالات بعد</td></tr>';
    }
    refreshSelect();
  }
  function saveDoctorFromForm(e){
    if(e){ e.preventDefault(); e.stopPropagation(); if(e.stopImmediatePropagation)e.stopImmediatePropagation(); }
    const name=String($id('savedDoctorName')?.value||'').trim();
    if(!name){safeMsg('err','اكتب اسم الطبيب أولاً');return false;}
    const id=String($id('savedDoctorId')?.value||'').trim()||makeDocId();
    let docs=loadDocs().filter(d=>d.id!==id && d.name!==name);
    docs.unshift({
      id,name,
      spec:$id('savedDoctorSpec')?.value||'',
      phone:$id('savedDoctorPhone')?.value||'',
      rate:Number($id('savedDoctorRate')?.value)||0,
      updatedAt:new Date().toISOString()
    });
    saveDocs(docs);
    const f=$id('savedDoctorForm'); if(f) f.reset(); if($id('savedDoctorId')) $id('savedDoctorId').value='';
    renderSavedDoctors();
    safeMsg('ok','تم حفظ الطبيب وظهر بقائمة الأطباء');
    return false;
  }
  function editDoc(id){
    const d=loadDocs().find(x=>String(x.id)===String(id)); if(!d) return;
    if($id('savedDoctorId')) $id('savedDoctorId').value=d.id;
    if($id('savedDoctorName')) $id('savedDoctorName').value=d.name||'';
    if($id('savedDoctorSpec')) $id('savedDoctorSpec').value=d.spec||'';
    if($id('savedDoctorPhone')) $id('savedDoctorPhone').value=d.phone||'';
    if($id('savedDoctorRate')) $id('savedDoctorRate').value=d.rate||0;
    try{ if(typeof showSec==='function') showSec('doctors'); }catch(e){}
    const n=$id('savedDoctorName'); if(n) n.focus();
  }
  function delDoc(id){
    if(!confirm('حذف الطبيب؟')) return;
    saveDocs(loadDocs().filter(d=>String(d.id)!==String(id)));
    renderSavedDoctors();
    safeMsg('ok','تم حذف الطبيب');
  }
  function saveDoctorRateFromForm(e){
    if(e){ e.preventDefault(); e.stopPropagation(); if(e.stopImmediatePropagation)e.stopImmediatePropagation(); }
    const name=String($id('drName')?.value||'').trim();
    if(!name){safeMsg('err','اكتب اسم الطبيب');return false;}
    const rate=Number($id('drRate')?.value)||0;
    const paid=Number($id('drPaid')?.value)||0;
    try{doctorRates=Array.isArray(doctorRates)?doctorRates.filter(x=>String(x.name||'').trim()!==name):[]; doctorRates.push({name,rate,paid});}catch(e){}
    const docs=loadDocs();
    const i=docs.findIndex(d=>d.name===name);
    if(i>=0) docs[i].rate=rate; else docs.unshift({id:makeDocId(),name,spec:'',phone:'',rate,updatedAt:new Date().toISOString()});
    saveDocs(docs);
    try{if(typeof renderAccounting==='function') renderAccounting();}catch(e){}
    renderSavedDoctors();
    safeMsg('ok','تم حفظ بيانات الطبيب');
    return false;
  }
  document.addEventListener('submit',function(e){
    if(e.target && e.target.id==='savedDoctorForm') return saveDoctorFromForm(e);
    if(e.target && e.target.id==='doctorRateForm') return saveDoctorRateFromForm(e);
  },true);
  document.addEventListener('click',function(e){
    const btn=e.target && e.target.closest && e.target.closest('#savedDoctorForm button');
    if(btn){ e.preventDefault(); return saveDoctorFromForm(e); }
  },true);
  try{loadSavedDoctors=loadDocs;}catch(e){} window.loadSavedDoctors=loadDocs;
  try{saveSavedDoctors=saveDocs;}catch(e){} window.saveSavedDoctors=saveDocs;
  try{refreshDoctorSelect=refreshSelect;}catch(e){} window.refreshDoctorSelect=refreshSelect;
  try{renderDoctors=renderSavedDoctors;}catch(e){} window.renderDoctors=renderSavedDoctors;
  try{editSavedDoctor=editDoc;}catch(e){} window.editSavedDoctor=editDoc;
  try{deleteSavedDoctor=delDoc;}catch(e){} window.deleteSavedDoctor=delDoc;
  function boot(){
    const f=$id('savedDoctorForm'); if(f){ f.setAttribute('novalidate','novalidate'); }
    renderSavedDoctors();
    refreshSelect();
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',boot); else boot();
  setTimeout(boot,400);
})();



