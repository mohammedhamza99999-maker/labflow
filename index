/* ===== Core repaired utilities: exact test classification, normal range fallback, modal close ===== */
function labflowCoreNorm(v){return String(v||'').toLowerCase().replace(/[إأآا]/g,'ا').replace(/ة/g,'ه').replace(/[^a-z0-9\u0600-\u06ff]+/g,' ').trim();}
function labflowCoreIsCBCMaster(it){
  const ft=String((it&&it.formType)||'').toLowerCase().trim();
  const txt=labflowCoreNorm([it&&it.name,it&&it.enName,it&&it.code].filter(Boolean).join(' '));
  return ft==='cbc' || /(^| )cbc( |$)/.test(txt) || txt==='complete blood count' || txt.includes(' complete blood count ') || txt.startsWith('complete blood count');
}
function labflowCoreSpecialKind(it){
  const ft=String((it&&it.formType)||'').toLowerCase().trim();
  const txt=labflowCoreNorm([it&&it.name,it&&it.enName,it&&it.code].filter(Boolean).join(' '));
  if(ft==='cbc' || labflowCoreIsCBCMaster(it)) return 'cbc';
  if(ft==='urine' || /(^| )g u e( |$)/.test(txt) || /(^| )gue( |$)/.test(txt) || txt.includes('general urine examination') || txt.includes('general urine exam') || txt.includes('تحليل الادرار العام') || txt.includes('ادرار عام')) return 'urine';
  if(ft==='stool' || /(^| )g s e( |$)/.test(txt) || /(^| )gse( |$)/.test(txt) || txt.includes('general stool examination') || txt.includes('stool general examination') || txt.includes('تحليل الخروج العام') || txt.includes('خروج عام')) return 'stool';
  return '';
}
function labflowFindTestForItem(it){
  try{
    if(!it || !Array.isArray(tests)) return null;
    if(it.testId){const byId=tests.find(t=>String(t.id)===String(it.testId)); if(byId) return byId;}
    const n=labflowCoreNorm(it.name), e=labflowCoreNorm(it.enName);
    return tests.find(t=>(n && labflowCoreNorm(t.name)===n) || (e && labflowCoreNorm(t.enName)===e)) || null;
  }catch(_){return null;}
}
function labflowNormalRangeForItem(it){
  const direct=(it&&(it.normalRange||it.range||it.normal||it.referenceRange||it.refRange))||'';
  if(String(direct).trim()) return direct;
  const t=labflowFindTestForItem(it);
  return (t&&(t.normalRange||t.range||t.normal||t.referenceRange||t.refRange)) || '-';
}
function labflowUnitForItem(it){
