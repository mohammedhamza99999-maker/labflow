/* ===== V49 RESULTS MODULE: ROOT FIX FOR EMPTY RESULTS PAGE =====
   Purpose: the saved orders were stored correctly, but the results table body
   had no authoritative renderer after older cleanup removed the original one.
   This module owns rendering #ordersBody and keeps the print dropdown synced. */
(function(){
  function h(v){try{return esc(v);}catch(e){return String(v==null?'':v).replace(/[&<>"']/g,function(m){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m];});}}
  function aid(v){return String(v==null?'':v).replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/\n/g,' ');}
  function listOrders(){try{return Array.isArray(orders)?orders:[]}catch(e){return [];}}
  function readableDate(o){
    try{return fmtDate(o.resultedAt||o.createdAt||o.dateKey||new Date());}
    catch(e){return String(o.dateKey||o.createdAt||'').slice(0,10)||'-';}
  }
  function orderStatus(o){
    const items=Array.isArray(o&&o.items)?o.items:[];
    const hasResult=items.some(function(it){return String((it&&it.result)||'').trim();});
    const label=(typeof statusText==='function')?statusText(o.status):(o.status||'جديدة');
    if(typeof status==='function') return status(o.status);
    const cls=o.status==='ready'?'ok':(hasResult?'warn':'');
    return '<span class="badge '+cls+'">'+h(label)+'</span>';
  }
  function testsSummary(o){
    const items=Array.isArray(o&&o.items)?o.items:[];
    if(!items.length) return '<span class="muted">لا توجد تحاليل</span>';
    const names=items.map(function(it){return it&&it.name?it.name:'';}).filter(Boolean);
    const shown=names.slice(0,4).map(h).join('، ');
    return shown+(names.length>4?' <span class="muted">+ '+(names.length-4)+'</span>':'');
  }
  function syncPrintOrderDropdown(selectedId){
    const sel=document.getElementById('printOrder');
    if(!sel) return;
    const keep=selectedId||sel.value;
    const rows=listOrders();
    sel.innerHTML=rows.length?rows.map(function(o){
      const txt=[o.orderNo,o.patientName,(typeof statusText==='function'?statusText(o.status):(o.status||''))].filter(Boolean).join(' - ');
      return '<option value="'+h(o.id)+'">'+h(txt)+'</option>';
    }).join(''):'<option value="">لا توجد طلبات</option>';
    if(keep && rows.some(function(o){return String(o.id)===String(keep);})){sel.value=keep;}
    else if(rows[0]) sel.value=rows[0].id;
  }
  function actionButtons(o){
    const id=aid(o.id), pid=aid(o.patientId||'');
    const fileBtn=pid?'<button type="button" class="btn small ghost" onclick="showPatientHistory(\''+pid+'\')">ملف المريض</button>':'';
    return '<div class="results-actions-clean">'
      +'<button type="button" class="btn small primary btn-result-print" onclick="openResults(\''+id+'\')">إدخال/تعديل النتائج</button>'
      +'<button type="button" class="btn small blue" onclick="quickPrint(\''+id+'\')">طباعة</button>'
      +fileBtn
      +'<button type="button" class="btn small danger" onclick="delDoc(\'orders\',\''+id+'\')">حذف</button>'
      +'</div>';
  }
  function resultsEmptyRow(){
    return '<tr><td colspan="6" style="text-align:center;padding:26px;color:#60758c">لا توجد طلبات محفوظة بعد. من صفحة تسجيل جديد، بعد الحفظ يظهر الطلب هنا مباشرة.</td></tr>';
  }
  window.renderOrders=function(){
    const body=document.getElementById('ordersBody');
    const rows=listOrders();
    syncPrintOrderDropdown();
    if(!body) return;
    body.innerHTML=rows.length?rows.map(function(o){
      return '<tr data-order="'+h(o.id)+'">'
        +'<td><b>'+h(o.orderNo||'-')+'</b></td>'
        +'<td><b>'+h(o.patientName||'-')+'</b><br><span class="muted">'+h(o.patientAge||'-')+' / '+h(o.patientGender||'-')+'</span></td>'
        +'<td>'+h(readableDate(o))+'</td>'
        +'<td>'+orderStatus(o)+'</td>'
        +'<td>'+testsSummary(o)+'</td>'
        +'<td>'+actionButtons(o)+'</td>'
        +'</tr>';
    }).join(''):resultsEmptyRow();
  };
  try{renderOrders=window.renderOrders;}catch(e){}

  // Keep the table fresh when the user enters the results page.
  const oldShowSec=window.showSec;
  if(typeof oldShowSec==='function' && !oldShowSec.__v49ResultsAware){
    const wrapped=function(id){
      const r=oldShowSec.apply(this,arguments);
      if(id==='results') setTimeout(function(){try{window.renderOrders();}catch(e){}},0);
      return r;
    };
    wrapped.__v49ResultsAware=true;
    window.showSec=wrapped;
    try{showSec=window.showSec;}catch(e){}
  }

  // Keep table fresh after save/delete/render cycles.
  const oldRenderAll=window.renderAll;
  if(typeof oldRenderAll==='function' && !oldRenderAll.__v49ResultsAware){
    const wrappedAll=function(){
      const r=oldRenderAll.apply(this,arguments);
      try{window.renderOrders();}catch(e){}
      return r;
    };
    wrappedAll.__v49ResultsAware=true;
    window.renderAll=wrappedAll;
    try{renderAll=window.renderAll;}catch(e){}
  }

  // Initial draw after the whole script finishes, because older loadAll ran before this module existed.
  setTimeout(function(){try{window.renderOrders();}catch(e){console.error('V49 results render failed',e);}},0);
  try{document.documentElement.dataset.labflowBuild='V49_RESULTS_ROOT_FIXED';}catch(e){}
})();


