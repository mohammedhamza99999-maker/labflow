  const oldLoadAll = window.loadAll;
  if(typeof oldLoadAll === 'function' && !oldLoadAll.__v58Wrapped){
    window.loadAll = function(){
      const r = oldLoadAll.apply(this, arguments);
      setTimeout(function(){
        protectSettingsSubmit();
        updateInterfaceLogo();
        wrapPrintBuilder();
      }, 120);
      return r;
    };
    window.loadAll.__v58Wrapped = true;
    try{ loadAll = window.loadAll; }catch(e){}
  }

  const oldShowSec = window.showSec;
  if(typeof oldShowSec === 'function' && !oldShowSec.__v58Wrapped){
    window.showSec = function(id){
      const r = oldShowSec.apply(this, arguments);
      setTimeout(function(){
        protectSettingsSubmit();
        updateInterfaceLogo();
        wrapPrintBuilder();
      }, 120);
      return r;
    };
    window.showSec.__v58Wrapped = true;
    try{ showSec = window.showSec; }catch(e){}
  }

  window.labflowEnhancePrintHtmlV58 = enhancePrintHtml;
  window.labflowUpdateVisibleLogoV58 = updateInterfaceLogo;

  document.addEventListener('DOMContentLoaded', function(){
    protectSettingsSubmit();
    updateInterfaceLogo();
    wrapPrintBuilder();
    setTimeout(function(){ protectSettingsSubmit(); updateInterfaceLogo(); wrapPrintBuilder(); }, 600);
    setTimeout(function(){ protectSettingsSubmit(); updateInterfaceLogo(); wrapPrintBuilder(); }, 1500);
  });

  setTimeout(function(){ protectSettingsSubmit(); updateInterfaceLogo(); wrapPrintBuilder(); }, 2600);
})();
</script>




<script id="v59-footer-sign-watermark-fix">
(function(){
