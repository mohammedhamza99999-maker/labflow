    if(topbar){
      const userbox=topbar.querySelector('.userbox');
      topbar.insertBefore(box,userbox||null);
    }else document.body.prepend(box);
    box.addEventListener('click',function(e){
      const b=e.target.closest('button[data-lang]'); if(!b) return;
      window.setLabFlowLanguage(b.dataset.lang);
    });
  }
