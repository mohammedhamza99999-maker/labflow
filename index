  document.addEventListener('DOMContentLoaded',()=>{ensurePhoneField();patchOrderSubmit();relabel();});
  setTimeout(()=>{ensurePhoneField();patchOrderSubmit();relabel();},200);
})();




/* ===== V36: WhatsApp PDF share + H/L with small arrows ===== */
(function(){
  const PATCH='V36_WHATSAPP_PDF_HL_ARROWS';
  const escV36=(v)=>String(v==null?'':v).replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
  const notify=(type,text)=>{try{if(typeof msg==='function')msg(type,text);else console.log(PATCH,text)}catch(e){console.log(PATCH,text)}};
  function cleanPhoneV36(p){let x=String(p||'').replace(/\D/g,''); if(x.startsWith('0'))x='964'+x.slice(1); if(!x.startsWith('964')&&x.length>8)x='964'+x; return x;}
  function getOrderV36(id){try{return (Array.isArray(orders)?orders:[]).find(o=>String(o.id)===String(id));}catch(e){return null}}
  function fileNameV36(o){
    const date=((o&&o.resultedAt)||new Date().toISOString()).slice(0,10);
    const name=(o&&o.patientName)||'patient';
    const safe=(typeof safeFileName==='function')?safeFileName:String(name).replace(/[\\/:*?"<>|]+/g,'_').trim();
    return safe+'_'+date+'.pdf';
  }
  async function makePdfV36(o){
    if(typeof makeResultPdfBlob==='function') return await makeResultPdfBlob(o);
    if(typeof buildResultPrintHtml==='function') return new Blob([buildResultPrintHtml(o,window.selectedTemplate||'classic',false)],{type:'text/html;charset=utf-8'});
    return new Blob([JSON.stringify(o,null,2)],{type:'application/json'});
  }
  function downloadBlobV36(blob,fileName){
    if(typeof downloadBlob==='function') return downloadBlob(blob,fileName);
    const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=fileName; document.body.appendChild(a); a.click(); setTimeout(()=>{URL.revokeObjectURL(a.href);a.remove();},1500);
  }
  function resultTextV36(o){
    return `Lab result is ready\nPatient: ${(o&&o.patientName)||'-'}\nOrder No: ${(o&&o.orderNo)||'-'}\nPDF result attached.`;
  }
  async function sharePdfToWhatsAppV36(o, target){
    const phone = target==='doctor'
      ? cleanPhoneV36((typeof loadSavedDoctors==='function'?((loadSavedDoctors().find(d=>d.name===o.doctor)||{}).phone):'') || o.doctorPhone || '')
      : cleanPhoneV36(o.patientPhone||'');
    const blob=await makePdfV36(o);
    const fileName=fileNameV36(o);
    const file=new File([blob],fileName,{type:'application/pdf'});
    const text=resultTextV36(o);
    // On mobile/modern browsers this shares the actual PDF file; choose WhatsApp from the share sheet.
    if(navigator.canShare && navigator.canShare({files:[file]})){
      await navigator.share({title:fileName,text,files:[file]});
      notify('ok','تم فتح مشاركة الملف. اختار WhatsApp حتى يندز ملف PDF ويا الرسالة.');
      return;
    }
    // Desktop WhatsApp Web cannot receive a local file through wa.me by browser security, so keep a ready PDF download + open chat.
    downloadBlobV36(blob,fileName);
    const url=(phone?'https://wa.me/'+phone:'https://wa.me/')+'?text='+encodeURIComponent(text+'\nPDF file downloaded and ready to attach.');
    window.open(url,'_blank');
    notify('ok','تم تجهيز وتنزيل ملف PDF وفتح واتساب. إذا أنت على الكمبيوتر، المتصفح يمنع إرفاق الملف تلقائياً؛ ارفق ملف PDF من التنزيلات. على الموبايل المشاركة ترسل الملف مباشرة.');
  }
  window.shareOrDownloadResultPdf=async function(o,phone){return sharePdfToWhatsAppV36(o,phone==='doctor'?'doctor':'patient')};
  try{shareOrDownloadResultPdf=window.shareOrDownloadResultPdf}catch(e){}
  window.sendWhatsApp=async function(id,target){
    const o=getOrderV36(id); if(!o) return notify('err','ما لكيت الطلب');
    try{await sharePdfToWhatsAppV36(o,target||'patient');}
    catch(err){console.error(PATCH,err); notify('err','تعذر تجهيز PDF للمشاركة: '+(err.message||err));}
  };
  try{sendWhatsApp=window.sendWhatsApp}catch(e){}

  const css=document.createElement('style');
  css.textContent=`
    .flag-hl-v36{display:inline-flex!important;align-items:center!important;justify-content:center!important;gap:1.1mm!important;min-width:9mm;height:7mm;padding:0 1.6mm;border-radius:999px;background:#fff1f2!important;border:1px solid #fecdd3!important;color:#dc2626!important;font:1000 13.5px Arial,sans-serif!important;line-height:1!important;white-space:nowrap!important}
    .flag-hl-v36 .mini-arr{font-size:9px!important;line-height:1!important;position:relative;top:-.25mm;color:#dc2626!important;font-weight:1000!important}
    .flag-hl-v36.low .mini-arr{top:.15mm}
  `;
  document.head.appendChild(css);
  const prevBuildV36=window.buildResultPrintHtml;
  if(typeof prevBuildV36==='function'){
    window.buildResultPrintHtml=function(o,tpl,autoPrint){
      let html=prevBuildV36.call(this,o,tpl,autoPrint);
      html=html.replace(/<span class="flag-hl-v35">H<\/span>/g,'<span class="flag-hl-v36 high">H<span class="mini-arr">▲</span></span>')
               .replace(/<span class="flag-hl-v35">L<\/span>/g,'<span class="flag-hl-v36 low">L<span class="mini-arr">▼</span></span>')
               .replace(/<span class="flag-arrow-v32">▲<\/span>/g,'<span class="flag-hl-v36 high">H<span class="mini-arr">▲</span></span>')
               .replace(/<span class="flag-arrow-v32">▼<\/span>/g,'<span class="flag-hl-v36 low">L<span class="mini-arr">▼</span></span>')
               .replace(/<\/style>/,`.flag-hl-v36{display:inline-flex!important;align-items:center!important;justify-content:center!important;gap:1.1mm!important;min-width:9mm;height:7mm;padding:0 1.6mm;border-radius:999px;background:#fff1f2!important;border:1px solid #fecdd3!important;color:#dc2626!important;font:1000 13.5px Arial,sans-serif!important;line-height:1!important;white-space:nowrap!important}.flag-hl-v36 .mini-arr{font-size:9px!important;line-height:1!important;position:relative;top:-.25mm;color:#dc2626!important;font-weight:1000!important}.flag-hl-v36.low .mini-arr{top:.15mm}</style>`);
      return html;
    };
    try{buildResultPrintHtml=window.buildResultPrintHtml}catch(e){}
  }
  function relabelFlagsV36(){
    document.querySelectorAll('select option[value="high"]').forEach(o=>{if(!/[↑▲]/.test(o.textContent))o.textContent='مرتفع H ↑';});
    document.querySelectorAll('select option[value="low"]').forEach(o=>{if(!/[↓▼]/.test(o.textContent))o.textContent='منخفض L ↓';});
  }
  const oldOpenV36=window.openResults;
  if(typeof oldOpenV36==='function'){
    window.openResults=function(){const r=oldOpenV36.apply(this,arguments); setTimeout(relabelFlagsV36,80); return r;};
