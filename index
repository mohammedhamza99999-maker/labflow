<script id="v58-logo-header-watermark-fix">
(function(){
  function $(id){ return document.getElementById(id); }
  function escAttr(v){
    return String(v==null?'':v).replace(/[&<>"']/g,function(m){
      return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m];
    });
  }
  function getLab(){
    try{ return (typeof lab !== 'undefined' && lab) ? lab : {}; }catch(e){ return {}; }
  }
  function labName(){
    const L=getLab();
    return String((L.name || 'LabFlow')).trim();
  }
  function logoSrc(){
    const L=getLab();
    try{
      if(L.logo) return L.logo;
      if(typeof currentLogo === 'function') return currentLogo();
      if(typeof generatedLogoDataUri === 'function') return generatedLogoDataUri(labName());
    }catch(e){}
    return '';
  }
  function setLogo(dataUrl){
    try{
      if(typeof lab === 'undefined' || !lab) window.lab = {};
      lab.logo = dataUrl;
      if(typeof save === 'function') save();
    }catch(e){}
  }
  function updateInterfaceLogo(){
    const src = logoSrc();
    if(!src) return;

    document.querySelectorAll('.logo').forEach(function(el){
      el.innerHTML = '<img src="'+escAttr(src)+'" alt="logo" style="width:100%;height:100%;object-fit:cover;border-radius:inherit">';
    });

    const preview = $('logoPreview');
    if(preview) preview.src = src;

    const previewName = $('logoPreviewName');
    if(previewName) previewName.textContent = labName();

    try{ if(typeof updateAppLogo === 'function') updateAppLogo(); }catch(e){}
  }
  function readFile(file){
    return new Promise(function(resolve,reject){
      const r=new FileReader();
      r.onload=function(){ resolve(r.result); };
      r.onerror=reject;
      r.readAsDataURL(file);
    });
  }

  // عند اختيار لوغو من الإعدادات: ينحفظ ويتغير لوغو الواجهة فوراً
  document.addEventListener('change', async function(e){
    const input = e.target;
    if(!input || input.id !== 'sLogo') return;

    const file = input.files && input.files[0];
    if(!file) return;

    if(!/^image\//.test(file.type || '')){
      alert('اختار ملف صورة فقط');
      return;
    }

    const dataUrl = await readFile(file);
    setLogo(dataUrl);
    updateInterfaceLogo();

    try{ if(typeof msg === 'function') msg('ok','تم رفع اللوغو وتطبيقه على الواجهة وورقة التحليل'); }catch(e){}
  }, true);

  // إذا المستخدم حفظ الإعدادات بدون اختيار لوغو جديد لا نمسح اللوغو القديم
  function protectSettingsSubmit(){
    const form = $('settingsForm');
