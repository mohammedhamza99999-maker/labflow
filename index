  document.addEventListener('DOMContentLoaded',()=>setTimeout(relabelFlagsV36,150));
  setTimeout(relabelFlagsV36,250);
})();




/* ===== V37: full patient result file + bright search field ===== */
(function(){
  const PATCH='V37_PATIENT_FULL_FILE_SEARCH_COLORS';
  const safe=(v)=>String(v==null?'':v).replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
  const getPatients=()=>{try{return Array.isArray(patients)?patients:[]}catch(e){return []}};
  const getOrders=()=>{try{return Array.isArray(orders)?orders:[]}catch(e){return []}};
  function fmt(v){try{if(typeof fmtDate==='function')return fmtDate(v)}catch(e){} return String(v||'-').slice(0,10)||'-'}
  function flagLabel(flag){
    if(flag==='high') return '<span class="v37-flag high">H <small>▲</small></span>';
    if(flag==='low') return '<span class="v37-flag low">L <small>▼</small></span>';
    return '<span class="v37-flag normal">Normal</span>';
  }
  function orderItemsRows(o){
    const items=Array.isArray(o&&o.items)?o.items:[];
    if(!items.length) return '<tr><td colspan="6" class="empty">No tests in this order</td></tr>';
    return items.map((it,idx)=>{
      const result = (it.result!=null && String(it.result).trim()) ? it.result : '-';
      return `<tr>
        <td>${idx+1}</td>
        <td><b>${safe(it.name||'-')}</b><small>${safe(it.enName||'')}</small></td>
        <td class="result">${safe(result)}</td>
        <td>${safe(labflowUnitForItem(it)||'')}</td>
        <td>${safe(labflowNormalRangeForItem(it)||'-')}</td>
        <td>${flagLabel(it.flag||'normal')}${it.note?`<div class="note">${safe(it.note)}</div>`:''}</td>
      </tr>`;
    }).join('');
  }
  function samePatient(o,p){
    if(!o||!p) return false;
    if(o.patientId && p.id && String(o.patientId)===String(p.id)) return true;
    const on=String(o.patientName||'').trim().toLowerCase();
    const pn=String(p.name||'').trim().toLowerCase();
    if(on && pn && on===pn) return true;
    return false;
  }
  function openFullPrint(orderId){
    const o=getOrders().find(x=>String(x.id)===String(orderId));
    if(!o){alert('Order not found');return;}
    try{
      if(typeof window.printReport==='function') window.printReport(o, window.selectedTemplate||'classic');
      else if(typeof window.buildResultPrintHtml==='function'){
        const w=window.open('','_blank','width=1100,height=800');
        w.document.write(window.buildResultPrintHtml(o,window.selectedTemplate||'classic',false));
        w.document.close();
      }
    }catch(err){console.error(PATCH,err);alert('Print file error: '+(err.message||err));}
  }
  window.openPatientFullPrintV37=openFullPrint;
  function buildPatientFile(p){
    const ordersForPatient=getOrders().filter(o=>samePatient(o,p)).sort((a,b)=>String(b.resultedAt||b.createdAt||b.dateKey||'').localeCompare(String(a.resultedAt||a.createdAt||a.dateKey||'')));
    const legacy=(p.history||[]).filter(h=>!ordersForPatient.some(o=>String(o.id)===String(h.orderId)));
    const ordersHtml=ordersForPatient.length?ordersForPatient.map((o,idx)=>{
      const status=(typeof statusText==='function')?statusText(o.status):(o.status||'-');
      const tests=(o.items||[]).map(i=>i.name).filter(Boolean).join('، ');
      return `<section class="order-card">
        <div class="order-head">
          <div><span>Result File #${idx+1}</span><h3>${safe(o.orderNo||'-')}</h3><p>${safe(tests||'-')}</p></div>
          <div class="order-actions">
            <button onclick="window.opener&&window.opener.openResults&&window.opener.openResults('${safe(o.id)}')">Edit Result</button>
            <button class="primary" onclick="window.opener&&window.opener.openPatientFullPrintV37&&window.opener.openPatientFullPrintV37('${safe(o.id)}')">Open / Print Sheet</button>
          </div>
        </div>
        <div class="mini-meta">
          <div><span>Date</span><b>${safe(fmt(o.resultedAt||o.createdAt||o.dateKey))}</b></div>
          <div><span>Status</span><b>${safe(status)}</b></div>
          <div><span>Doctor</span><b>${safe(o.doctor||p.doctor||'-')}</b></div>
          <div><span>Phone</span><b>${safe(o.patientPhone||p.phone||'-')}</b></div>
        </div>
        <table><thead><tr><th>#</th><th>Test</th><th>Result</th><th>Unit</th><th>Normal Range</th><th>Flag / Note</th></tr></thead><tbody>${orderItemsRows(o)}</tbody></table>
      </section>`;
    }).join(''):'';
