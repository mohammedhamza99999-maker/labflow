<script>
(function(){
    const firebaseConfig = {
        apiKey: "AIzaSyB5MTJRDNILD3KalDIMmdOQxGFPsBgwOC8",
        authDomain: "labflow-a8cdc.firebaseapp.com",
        databaseURL: "https://labflow-a8cdc-default-rtdb.firebaseio.com",
        projectId: "labflow-a8cdc",
        storageBucket: "labflow-a8cdc.firebasestorage.app",
        messagingSenderId: "23108604166",
        appId: "1:23108604166:web:d4888aa101507391e9ce87"
    };

    if (!firebase.apps.length) {
        firebase.initializeApp(firebaseConfig);
    }

    const lfAuth = firebase.auth();
    const lfDb = firebase.database();

    function getDeviceId() {
        let deviceId = localStorage.getItem('device_id');
        if (!deviceId) {
            deviceId = 'device_' + Date.now() + '_' + Math.random().toString(36).slice(2, 12);
            localStorage.setItem('device_id', deviceId);
        }
        return deviceId;
    }

    function goLogin() {
        window.location.href = 'login.html';
    }

    lfAuth.onAuthStateChanged((user) => {
        if (!user) {
            goLogin();
            return;
        }

        const deviceId = getDeviceId();

        lfDb.ref('users/' + user.uid).once('value').then((snapshot) => {
            const userData = snapshot.val();

            if (!userData) {
                alert("حسابك غير موجود في قاعدة البيانات. سجّل دخولك من صفحة login.html مرة ثانية.");
                lfAuth.signOut().then(goLogin);
                return;
            }

            if (userData.status === 'suspended') {
                alert("عذراً، تم إيقاف حسابك من قبل الإدارة.");
                lfAuth.signOut().then(goLogin);
                return;
            }

            if (!userData.activeDevices || !userData.activeDevices[deviceId]) {
                alert("هذا الجهاز غير مصرح له أو تم تجاوز عدد الأجهزة المسموح بها.");
                lfAuth.signOut().then(goLogin);
                return;
            }
        }).catch((error) => {
            console.error("Firebase protection error:", error);
            alert("صار خطأ بالتحقق من الحساب. حاول تسجيل الدخول مرة ثانية.");
            lfAuth.signOut().then(goLogin);
        });
    });

    window.systemLogout = function() {
        const user = lfAuth.currentUser;
        const deviceId = localStorage.getItem('device_id');

        if (user && deviceId) {
            lfDb.ref('users/' + user.uid + '/activeDevices/' + deviceId).remove().finally(() => {
                lfAuth.signOut().then(goLogin);
            });
        } else {
            lfAuth.signOut().then(goLogin);
        }
    };
})();
</script>
